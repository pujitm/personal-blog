---
import Base from "../../layouts/BaseLayout.astro";

const title = "The Grading Conference 2026";
const description =
  "Notes from The Grading Conference 2026 on grades, communication, AI, and education.";

const postModules = import.meta.glob("./*.{md,mdx}", { eager: true });
const posts = (
  Object.values(postModules) as Array<{
    frontmatter: {
      draft?: boolean;
      pubDate: string;
      title: string;
      description?: string;
    };
    url?: string;
  }>
)
  .filter((post) => !post.frontmatter.draft)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.pubDate).valueOf() -
      new Date(a.frontmatter.pubDate).valueOf()
  );
---

<Base title={title} description={description}>
  <main class="mx-4 pb-20">
    <article
      class="mx-auto max-w-3xl text-neutral-900/95 dark:text-neutral-100/90"
    >
      <header class="mb-12">
        <p class="mb-4 text-sm uppercase tracking-widest text-neutral-600 dark:text-neutral-300">
          The Grading Conference 2026
        </p>
        <h1 class="font-serif text-4xl leading-tight md:text-5xl">
          The future of grades as communication
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-700 dark:text-neutral-200">
          I am presenting a poster about moving grades from compressed
          interpretations toward richer records of observation. This page is a
          place for notes around that presentation, responses to other work at
          the conference, and broader thoughts on education.
        </p>
      </header>

      <section class="mb-14">
        <a href="/grading-conf-26-poster.png" aria-label="Open poster image">
          <img
            src="/grading-conf-26-poster.png"
            alt="Poster titled The future of grades as communication"
            class="w-full border border-neutral-300 bg-white dark:border-neutral-700"
          />
        </a>
      </section>

      <section class="prose prose-stone max-w-none dark:prose-invert">
        <h2>Writing</h2>
        {
          posts.length > 0 ? (
            <ul>
              {posts.map((post) => (
                <li>
                  <a href={post.url}>{post.frontmatter.title}</a>
                  {post.frontmatter.description && (
                    <span> — {post.frontmatter.description}</span>
                  )}
                </li>
              ))}
            </ul>
          ) : (
            <p>
              I will collect conference notes and follow-up essays here as they
              are written.
            </p>
          )
        }
      </section>
    </article>
  </main>
</Base>
