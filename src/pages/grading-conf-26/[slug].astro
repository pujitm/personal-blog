---
import GradingConferenceLayout from "../../layouts/GradingConferenceLayout.astro";
import { essays } from "../../lib/grading-conf-26";

export function getStaticPaths() {
    return essays.map((essay, index) => ({
        params: { slug: essay.slug },
        props: {
            essay,
            nextEssay: essays[index + 1],
            previousEssay: essays[index - 1],
        },
    }));
}

const { essay, nextEssay, previousEssay } = Astro.props;
const title = `${essay.abstractTitle} | The Grading Conference 2026`;
const description = `Essay inspired by ${essay.author}'s abstract at The Grading Conference 2026.`;
---

<GradingConferenceLayout
    title={title}
    description={description}
    bodyClass="essay-page"
>
    <main class="page-shell">
        <article>
            <header class="hero">
                <p class="essay-number">#{essay.number}</p>
                <p class="inspired-by">Inspired by</p>
                <h1>{essay.abstractTitle}</h1>
                <p class="byline">{essay.author}</p>
            </header>

            <div class="reading-panel">
                <details class="abstract-panel">
                    <summary>Original abstract</summary>
                    <div class="abstract-copy">
                        {essay.abstract.map((paragraph) => <p>{paragraph}</p>)}
                    </div>
                </details>

                <div class="essay-body">
                    {essay.essay.map((paragraph) => <p>{paragraph}</p>)}
                </div>
            </div>
        </article>

        <nav class="essay-nav" aria-label="Essay navigation">
            {
                previousEssay ? (
                    <a
                        class="essay-nav-link essay-nav-previous"
                        href={`/grading-conf-26/${previousEssay.slug}`}
                    >
                        <span>Previous</span>
                        {previousEssay.abstractTitle}
                    </a>
                ) : (
                    <span />
                )
            }
            {
                nextEssay && (
                    <a
                        class="essay-nav-link essay-nav-next"
                        href={`/grading-conf-26/${nextEssay.slug}`}
                    >
                        <span>Next</span>
                        {nextEssay.abstractTitle}
                    </a>
                )
            }
        </nav>

        <a class="back-link back-link-bottom" href="/grading-conf-26"
            >Back to series</a
        >
    </main>
</GradingConferenceLayout>
