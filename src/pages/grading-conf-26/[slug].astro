---
import GradingConferenceLayout from "../../layouts/GradingConferenceLayout.astro";
import { essays } from "../../lib/grading-conf-26";

export function getStaticPaths() {
  return essays.map((essay) => ({
    params: { slug: essay.slug },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const title = `${essay.abstractTitle} | The Grading Conference 2026`;
const description = `Essay inspired by ${essay.author}'s abstract at The Grading Conference 2026.`;
---

<GradingConferenceLayout title={title} description={description} bodyClass="essay-page">
  <main class="page-shell">
    <article>
      <header class="hero">
        <p class="essay-number">#{essay.number}</p>
        <p class="inspired-by">Inspired by</p>
        <h1>{essay.abstractTitle}</h1>
        <p class="byline">{essay.author}</p>
      </header>

      <details class="abstract-panel">
        <summary>Original abstract</summary>
        <div class="abstract-copy">
          {essay.abstract.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </details>

      <div class="essay-body">
        {essay.essay.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </article>

    <a class="back-link back-link-bottom" href="/grading-conf-26">Back to series</a>
  </main>
</GradingConferenceLayout>
